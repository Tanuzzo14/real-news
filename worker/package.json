{
  "name": "real-news-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute real-news-db --local --file=./migrations/0001_create_news_posts.sql",
    "db:migrate:remote": "wrangler d1 execute real-news-db --remote --file=./migrations/0001_create_news_posts.sql"
  },
  "dependencies": {
    "rss-parser": "^3.13.0",
    "@google/generative-ai": "^0.21.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "typescript": "^5.3.3",
    "wrangler": "^3.114.17"
  }
}
